{
  "name": "random-file-navigator",
  "displayName": "Random File Navigator",
  "description": "Navigate through all files in your workspace in a randomised order, cycling through root files and nested folder files alike.",
  "version": "0.1.0",
  "publisher": "cursor-ext",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "random",
    "navigation",
    "files",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/random-file-navigator"
  },
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "randomFileNavigator.nextFile",
        "title": "Random File Navigator: Next Random File"
      },
      {
        "command": "randomFileNavigator.prevFile",
        "title": "Random File Navigator: Previous File"
      },
      {
        "command": "randomFileNavigator.reshuffle",
        "title": "Random File Navigator: Reshuffle & Restart"
      },
      {
        "command": "randomFileNavigator.showQueue",
        "title": "Random File Navigator: Show File Queue"
      },
      {
        "command": "randomFileNavigator.setInterval",
        "title": "Random File Navigator: Set Auto-Advance Interval… (Legacy)"
      },
      {
        "command": "randomFileNavigator.setRange",
        "title": "Random File Navigator: Set Auto-Advance Range…"
      },
      {
        "command": "randomFileNavigator.startAutoAdvance",
        "title": "Random File Navigator: Start Auto-Advance"
      },
      {
        "command": "randomFileNavigator.stopAutoAdvance",
        "title": "Random File Navigator: Stop Auto-Advance"
      },
      {
        "command": "randomFileNavigator.toggleAutoAdvance",
        "title": "Random File Navigator: Toggle Auto-Advance"
      }
    ],
    "keybindings": [
      {
        "command": "randomFileNavigator.nextFile",
        "key": "ctrl+shift+]",
        "mac": "cmd+shift+]"
      },
      {
        "command": "randomFileNavigator.prevFile",
        "key": "ctrl+shift+[",
        "mac": "cmd+shift+["
      },
      {
        "command": "randomFileNavigator.toggleAutoAdvance",
        "key": "ctrl+shift+\\",
        "mac": "cmd+shift+\\"
      }
    ],
    "configuration": {
      "title": "Random File Navigator",
      "properties": {
        "randomFileNavigator.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/vendor/**",
            "**/vendors/**",
            "**/.git/**",
            "**/.svn/**",
            "**/.hg/**",
            "**/dist/**",
            "**/build/**",
            "**/out/**",
            "**/output/**",
            "**/bin/**",
            "**/obj/**",
            "**/.next/**",
            "**/.nuxt/**",
            "**/.svelte-kit/**",
            "**/.vite/**",
            "**/.turbo/**",
            "**/.cache/**",
            "**/.parcel-cache/**",
            "**/__pycache__/**",
            "**/.venv/**",
            "**/venv/**",
            "**/env/**",
            "**/.env/**",
            "**/site-packages/**",
            "**/Pods/**",
            "**/.gradle/**",
            "**/target/**",
            "**/coverage/**",
            "**/.nyc_output/**",
            "**/logs/**",
            "**/*.pyc",
            "**/*.pyo",
            "**/*.class",
            "**/*.o",
            "**/*.a",
            "**/*.lib",
            "**/*.dll",
            "**/*.so",
            "**/*.dylib",
            "**/*.exe",
            "**/*.lock",
            "**/*.log",
            "**/.DS_Store",
            "**/Thumbs.db",
            "**/*.vsix",
            "**/*.min.js",
            "**/*.min.css",
            "**/*.map",
            "**/public/**",
            "**/public/assets/**",
            "**/private/**",
            "**/private/assets/**",
            "**/*.pdf",
            "**/*.docx",
            "**/*.doc",
            "**/*.xls",
            "**/*.xlsx",
            "**/*.ppt",
            "**/*.pptx",
            "**/*.txt",
            "**/*.csv",
            "**/*.png",
            "**/*.jpg",
            "**/*.jpeg",
            "**/*.gif",
            "**/*.bmp",
            "**/*.tiff",
            "**/*.ico",
            "**/*.webp",
            "**/*.svg",
            "**/*.ico",
            "**/*.webp",
            "**/*.svg",
            "**/*.ico",
            "**/*.webp",
            "**/*.svg",
            "**/*.ico",
            "**/*.webp",
            "**/*.json",
            "**/*.yaml",
            "**/*.yml",
            "**/*.xml",
            "**/*.md",
            "**/*.deployment",
            "**/__tests__/**",
            "**/storage/**"
          ],
          "description": "Glob patterns to exclude when building the file queue."
        },
        "randomFileNavigator.includePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*"
          ],
          "description": "Glob patterns for files to include in the queue."
        },
        "randomFileNavigator.autoReshuffle": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reshuffle when the queue is exhausted."
        },
        "randomFileNavigator.showProgressInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show current queue position in the status bar."
        },
        "randomFileNavigator.autoAdvanceInterval": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Legacy single-value auto-advance interval in seconds. Kept for backward compatibility."
        },
        "randomFileNavigator.autoAdvanceMinSeconds": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Minimum number of seconds to keep each file open before auto-advancing."
        },
        "randomFileNavigator.autoAdvanceMaxSeconds": {
          "type": "number",
          "default": 45,
          "minimum": 1,
          "description": "Maximum number of seconds to keep each file open before auto-advancing."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "typescript": "^5.3.0"
  }
}
